# Copy this file to .env for local reference.
# Note: plain PHP does not auto-load .env — these values are read via
# environment variables (see docker-compose.yml / Render dashboard).
# For local XAMPP use, config/database.php already falls back to these defaults.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=agrilink
DB_USER=agrilink_user
DB_PASSWORD=agrilink_pass
